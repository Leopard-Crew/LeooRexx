librxsock_la_LDFLAGS = $(VERSION_INFO) @ORX_LDFLAGS_LIBRARY@

#################### librxregexp.so ################
# Preprocessor flags for librxregexp.so
#
librxregexp_la_CXXFLAGS = $(COMMON_CPPFLAGS) \
                          -I$(top_srcdir)/lib \
                          -I$(kernel_dir) \
                          -I$(expression_dir) \
                          -I$(classes_dir) \
                          -I$(messages_dir) \
                          -I$(kernel_platform_common_dir) \
                          -I$(runtime_dir) \
                          -I$(kernel_platform_unix_dir) \
                          -I$(rexxapi_unix_dir)

#
# Sources for librxregexp.so
#
librxregexp_la_SOURCES = $(rxregexp_dir)/automaton.cpp \
                         $(rxregexp_dir)/dblqueue.cpp \
                         $(rxregexp_dir)/rxregexp.cpp

#
# Extra libraries for librxregexp.so (maybe)
#
librxregexp_la_LIBADD = @ORX_LIBADD_LIBRARY@
librxregexp_la_LDFLAGS = $(VERSION_INFO) @ORX_LDFLAGS_LIBRARY@

#
# distribution files
#
EXTRA_DIST = $(messages_dir)/RexxMessageNumbers.xsl \
             $(messages_dir)/RexxErrorCodes.xsl \
             $(messages_dir)/RexxMessageTable.xsl \
             $(messages_dir)/DocBookErrors.xsl \
             $(messages_dir)/DocErrorMessages.sgml \
             $(messages_dir)/gencat.inp \
             $(messageXML) \
             $(kernel_platform_unix_dir)/UnixGencat.xsl \
             $(errorHeaders) \
             $(platform_unix_dir)/rexx.sh \
             $(platform_unix_dir)/rexx.csh \
             $(rxregexp_dir)/rxregexp.cls \
             $(kernel_platform_unix_dir)/UnixMethods.orx \
             $(kernel_platform_unix_dir)/PlatformObjects.orx \
             $(rexxclasses_dir) \
             $(somHeaders) \
             $(classesHeaders) \
             $(expressionHeaders) \
             $(instructionsHeaders) \
             $(parserHeaders) \
             $(platformHeaders) \
             $(platformcommonHeaders) \
             $(runtimeHeaders) \
             $(streamlibraryHeaders) \
             $(libHeaders) \
             $(rexxapiHeaders) \
             $(rexxapiunixHeaders) \
             $(rxregexpHeaders) \
             $(rexutilsHeaders) \
             $(man_MANS) \
             $(miscFiles) \
             $(windowsFiles) \
             $(windowsDefFiles)

all: $(BUILT_SOURCES) config.h
	$(MAKE) $(AM_MAKEFLAGS) all-recursive

.SUFFIXES:
.SUFFIXES: .c .cpp .lo .o .obj
am--refresh:
	@:
$(srcdir)/Makefile.in:  $(srcdir)/Makefile.am $(top_srcdir)/oorexx.ver $(am__configure_deps)
	@for dep in $?; do \
	  case '$(am__configure_deps)' in \
	    *$$dep*) \
	      echo ' cd $(srcdir) && $(AUTOMAKE) --foreign '; \
	      cd $(srcdir) && $(AUTOMAKE) --foreign  \
		&& exit 0; \
	      exit 1;; \
	  esac; \
	done; \
	echo ' cd $(top_srcdir) && $(AUTOMAKE) --foreign  Makefile'; \
	cd $(top_srcdir) && \
	  $(AUTOMAKE) --foreign  Makefile
.PRECIOUS: Makefile
Makefile: $(srcdir)/Makefile.in $(top_builddir)/config.status
	@case '$?' in \
	  *config.status*) \
	    echo ' $(SHELL) ./config.status'; \
	    $(SHELL) ./config.status;; \
	  *) \
	    echo ' cd $(top_builddir) && $(SHELL) ./config.status $@ $(am__depfiles_maybe)'; \
	    cd $(top_builddir) && $(SHELL) ./config.status $@ $(am__depfiles_maybe);; \
	esac;

$(top_builddir)/config.status: $(top_srcdir)/configure $(CONFIG_STATUS_DEPENDENCIES)
	$(SHELL) ./config.status --recheck

$(top_srcdir)/configure:  $(am__configure_deps)
	cd $(srcdir) && $(AUTOCONF)
$(ACLOCAL_M4):  $(am__aclocal_m4_deps)
	cd $(srcdir) && $(ACLOCAL) $(ACLOCAL_AMFLAGS)

config.h: stamp-h1
	@if test ! -f $@; then \
	  rm -f stamp-h1; \
	  $(MAKE) stamp-h1; \
	else :; fi

stamp-h1: $(srcdir)/config.h.in $(top_builddir)/config.status
	@rm -f stamp-h1
	cd $(top_builddir) && $(SHELL) ./config.status config.h
$(srcdir)/config.h.in:  $(am__configure_deps) 
	cd $(top_srcdir) && $(AUTOHEADER)
	rm -f stamp-h1
	touch $@

distclean-hdr:
	-rm -f config.h stamp-h1
platform/unix/oorexx.spec: $(top_builddir)/config.status $(top_srcdir)/platform/unix/oorexx.spec.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
platform/unix/debian/changelog: $(top_builddir)/config.status $(top_srcdir)/platform/unix/debian/changelog.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
platform/unix/debian/postinst: $(top_builddir)/config.status $(top_srcdir)/platform/unix/debian/postinst.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
xsl.sh: $(top_builddir)/config.status $(srcdir)/xsl.sh.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
platform/unix/oorexx-config: $(top_builddir)/config.status $(top_srcdir)/platform/unix/oorexx-config.in
	cd $(top_builddir) && $(SHELL) ./config.status $@
install-pkglibLTLIBRARIES: $(pkglib_LTLIBRARIES)
	@$(NORMAL_INSTALL)
	test -z "$(pkglibdir)" || $(mkdir_p) "$(DESTDIR)$(pkglibdir)"
	@list='$(pkglib_LTLIBRARIES)'; for p in $$list; do \
	  if test -f $$p; then \
	    f=$(am__strip_dir) \
	    echo " $(LIBTOOL) --mode=install $(pkglibLTLIBRARIES_INSTALL) $(INSTALL_STRIP_FLAG) '$$p' '$(DESTDIR)$(pkglibdir)/$$f'"; \
	    $(LIBTOOL) --mode=install $(pkglibLTLIBRARIES_INSTALL) $(INSTALL_STRIP_FLAG) "$$p" "$(DESTDIR)$(pkglibdir)/$$f"; \
	  else :; fi; \
	done

uninstall-pkglibLTLIBRARIES:
	@$(NORMAL_UNINSTALL)
	@set -x; list='$(pkglib_LTLIBRARIES)'; for p in $$list; do \
	  p=$(am__strip_dir) \
	  echo " $(LIBTOOL) --mode=uninstall rm -f '$(DESTDIR)$(pkglibdir)/$$p'"; \
	  $(LIBTOOL) --mode=uninstall rm -f "$(DESTDIR)$(pkglibdir)/$$p"; \
	done

clean-pkglibLTLIBRARIES:
	-test -z "$(pkglib_LTLIBRARIES)" || rm -f $(pkglib_LTLIBRARIES)
	@list='$(pkglib_LTLIBRARIES)'; for p in $$list; do \
	  dir="`echo $$p | sed -e 's|/[^/]*$$||'`"; \
	  test "$$dir" != "$$p" || dir=.; \
	  echo "rm -f \"$${dir}/so_locations\""; \
	  rm -f "$${dir}/so_locations"; \
	done
librexx.la: $(librexx_la_OBJECTS) $(librexx_la_DEPENDENCIES) 
	$(CXXLINK) -rpath $(pkglibdir) $(librexx_la_LDFLAGS) $(librexx_la_OBJECTS) $(librexx_la_LIBADD) $(LIBS)
librexxapi.la: $(librexxapi_la_OBJECTS) $(librexxapi_la_DEPENDENCIES) 
	$(CXXLINK) -rpath $(pkglibdir) $(librexxapi_la_LDFLAGS) $(librexxapi_la_OBJECTS) $(librexxapi_la_LIBADD) $(LIBS)
librexxutil.la: $(librexxutil_la_OBJECTS) $(librexxutil_la_DEPENDENCIES) 
	$(CXXLINK) -rpath $(pkglibdir) $(librexxutil_la_LDFLAGS) $(librexxutil_la_OBJECTS) $(librexxutil_la_LIBADD) $(LIBS)
librxmath.la: $(librxmath_la_OBJECTS) $(librxmath_la_DEPENDENCIES) 
	$(CXXLINK) -rpath $(pkglibdir) $(librxmath_la_LDFLAGS) $(librxmath_la_OBJECTS) $(librxmath_la_LIBADD) $(LIBS)
librxregexp.la: $(librxregexp_la_OBJECTS) $(librxregexp_la_DEPENDENCIES) 
	$(CXXLINK) -rpath $(pkglibdir) $(librxregexp_la_LDFLAGS) $(librxregexp_la_OBJECTS) $(librxregexp_la_LIBADD) $(LIBS)
librxsock.la: $(librxsock_la_OBJECTS) $(librxsock_la_DEPENDENCIES) 
	$(LINK) -rpath $(pkglibdir) $(librxsock_la_LDFLAGS) $(librxsock_la_OBJECTS) $(librxsock_la_LIBADD) $(LIBS)
install-binPROGRAMS: $(bin_PROGRAMS)
	@$(NORMAL_INSTALL)
	test -z "$(bindir)" || $(mkdir_p) "$(DESTDIR)$(bindir)"
	@list='$(bin_PROGRAMS)'; for p in $$list; do \
	  p1=`echo $$p|sed 's/$(EXEEXT)$$//'`; \
	  if test -f $$p \
	     || test -f $$p1 \
	  ; then \
	    f=`echo "$$p1" | sed 's,^.*/,,;$(transform);s/$$/$(EXEEXT)/'`; \
	   echo " $(INSTALL_PROGRAM_ENV) $(LIBTOOL) --mode=install $(binPROGRAMS_INSTALL) '$$p' '$(DESTDIR)$(bindir)/$$f'"; \
	   $(INSTALL_PROGRAM_ENV) $(LIBTOOL) --mode=install $(binPROGRAMS_INSTALL) "$$p" "$(DESTDIR)$(bindir)/$$f" || exit 1; \
	  else :; fi; \
	done

uninstall-binPROGRAMS:
	@$(NORMAL_UNINSTALL)
	@list='$(bin_PROGRAMS)'; for p in $$list; do \
	  f=`echo "$$p" | sed 's,^.*/,,;s/$(EXEEXT)$$//;$(transform);s/$$/$(EXEEXT)/'`; \
	  echo " rm -f '$(DESTDIR)$(bindir)/$$f'"; \
	  rm -f "$(DESTDIR)$(bindir)/$$f"; \
	done

clean-binPROGRAMS:
	@list='$(bin_PROGRAMS)'; for p in $$list; do \
	  f=`echo $$p|sed 's/$(EXEEXT)$$//'`; \
	  echo " rm -f $$p $$f"; \
	  rm -f $$p $$f ; \
	done
rexx$(EXEEXT): $(rexx_OBJECTS) $(rexx_DEPENDENCIES) 
	@rm -f rexx$(EXEEXT)
	$(CXXLINK) $(rexx_LDFLAGS) $(rexx_OBJECTS) $(rexx_LDADD) $(LIBS)
rexxc$(EXEEXT): $(rexxc_OBJECTS) $(rexxc_DEPENDENCIES) 
	@rm -f rexxc$(EXEEXT)
	$(CXXLINK) $(rexxc_LDFLAGS) $(rexxc_OBJECTS) $(rexxc_LDADD) $(LIBS)
rxdelipc$(EXEEXT): $(rxdelipc_OBJECTS) $(rxdelipc_DEPENDENCIES) 
	@rm -f rxdelipc$(EXEEXT)
	$(CXXLINK) $(rxdelipc_LDFLAGS) $(rxdelipc_OBJECTS) $(rxdelipc_LDADD) $(LIBS)
rxmigrate$(EXEEXT): $(rxmigrate_OBJECTS) $(rxmigrate_DEPENDENCIES) 
	@rm -f rxmigrate$(EXEEXT)
	$(CXXLINK) $(rxmigrate_LDFLAGS) $(rxmigrate_OBJECTS) $(rxmigrate_LDADD) $(LIBS)
rxqueue$(EXEEXT): $(rxqueue_OBJECTS) $(rxqueue_DEPENDENCIES) 
	@rm -f rxqueue$(EXEEXT)
	$(CXXLINK) $(rxqueue_LDFLAGS) $(rxqueue_OBJECTS) $(rxqueue_LDADD) $(LIBS)
rxsubcom$(EXEEXT): $(rxsubcom_OBJECTS) $(rxsubcom_DEPENDENCIES) 
	@rm -f rxsubcom$(EXEEXT)
	$(CXXLINK) $(rxsubcom_LDFLAGS) $(rxsubcom_OBJECTS) $(rxsubcom_LDADD) $(LIBS)
install-pkgdataSCRIPTS: $(pkgdata_SCRIPTS)
	@$(NORMAL_INSTALL)
	test -z "$(pkgdatadir)" || $(mkdir_p) "$(DESTDIR)$(pkgdatadir)"
	@list='$(pkgdata_SCRIPTS)'; for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  if test -f $$d$$p; then \
	    f=`echo "$$p" | sed 's|^.*/||;$(transform)'`; \
	    echo " $(pkgdataSCRIPT_INSTALL) '$$d$$p' '$(DESTDIR)$(pkgdatadir)/$$f'"; \
	    $(pkgdataSCRIPT_INSTALL) "$$d$$p" "$(DESTDIR)$(pkgdatadir)/$$f"; \
	  else :; fi; \
	done

uninstall-pkgdataSCRIPTS:
	@$(NORMAL_UNINSTALL)
	@list='$(pkgdata_SCRIPTS)'; for p in $$list; do \
	  f=`echo "$$p" | sed 's|^.*/||;$(transform)'`; \
	  echo " rm -f '$(DESTDIR)$(pkgdatadir)/$$f'"; \
	  rm -f "$(DESTDIR)$(pkgdatadir)/$$f"; \
	done

mostlyclean-compile:
	-rm -f *.$(OBJEXT)

distclean-compile:
	-rm -f *.tab.c

