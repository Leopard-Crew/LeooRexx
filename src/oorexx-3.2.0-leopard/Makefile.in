            $(samples_windows_dir)/* \
            $(samples_dir)/readme

windowsFiles = \
            $(top_srcdir)/makeorx.bat \
            $(top_srcdir)/orxdb.bat \
            $(top_srcdir)/windows-build.txt \
            $(lib_dir)/*.mak \
            $(kernel_platform_windows_dir)/*.cpp \
            $(kernel_platform_windows_dir)/*.h \
            $(kernel_platform_windows_dir)/*.rc \
