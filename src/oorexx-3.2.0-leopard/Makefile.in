SUBDIRS = samples
DIST_SUBDIRS = samples

# This defines the current version of ooRexx
ORX_MAJOR = 3
ORX_MINOR = 2
ORX_MOD_LVL = 0
ORX_BLD_LVL = 1
ORX_VER_STR = "3.2.0.1"
ORX_COPY_YEAR = "2005-2007"

# This defines the oorexx library version. For ooRexx this should always be the
# same as the ORX_MAJOR number.
ORX_CURRENT = $(ORX_MAJOR)
# Each public release of ooRexx should increment this number by one.
ORX_REVISION = 4
# For ooRexx, this number should ALWAYS be zero. This will force the linker to
# utilize all previous releases for linking.
ORX_AGE = 0
#driver_name = orexx-$(ORX_MAJOR).$(ORX_MINOR).$(ORX_MOD_LVL).0-$(ORX_BLD_LVL)

# Please note that the version-info has nothing to do with the release version.
# You need to know exactly what you are doing in order to get this correct.
VERSION_INFO = -version-info ${ORX_CURRENT}:${ORX_REVISION}:${ORX_AGE}
