                          -I$(lib_dir) \
                          -I$(kernel_dir) \
                          -I$(expression_dir) \
                          -I$(instructions_dir) \
                          -I$(classes_dir) \
                          -I$(runtime_dir) \
                          -I$(parser_dir) \
                          -I$(messages_dir) \
                          -I$(kernel_platform_common_dir) \
                          -I$(kernel_platform_unix_dir) \
                          -I$(rexxapi_dir) \
                          -I$(rexxapi_unix_dir)

librexxapi_la_LDFLAGS = $(VERSION_INFO)

